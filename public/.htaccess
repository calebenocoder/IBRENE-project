<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- SPA fallback: serve index.html for all non-file, non-directory routes ---
  # Prerendered /evento/[slug]/index.html files WILL be served as directories by Apache,
  # so the !-d condition here correctly lets Apache serve the prerendered file for bots AND users.
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-e
  RewriteRule . /index.html [L]
</IfModule>
